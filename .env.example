# Firebase Configuration
# Get these from: https://console.firebase.google.com/project/_/settings/general
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your_project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Supabase S3 Configuration (for Posts/Media storage)
# Get these from: https://supabase.com/dashboard/project/_/storage/settings
# Click "Generate S3 Access Keys" to create credentials
VITE_SUPABASE_PROJECT_REF=your_project_ref
VITE_SUPABASE_REGION=ap-south-1
VITE_SUPABASE_ACCESS_KEY_ID=your_access_key_id
VITE_SUPABASE_SECRET_ACCESS_KEY=your_secret_access_key

# Supabase S3 Configuration (for Chat media storage)
# Can be same as above or a separate bucket
VITE_CHAT_SUPABASE_PROJECT_REF=your_chat_project_ref
VITE_CHAT_SUPABASE_REGION=ap-south-1
VITE_CHAT_SUPABASE_ACCESS_KEY_ID=your_chat_access_key_id
VITE_CHAT_SUPABASE_SECRET_ACCESS_KEY=your_chat_secret_access_key

# AI Provider - A4F (for Image editing and generation)
# Get your API key from: https://a4f.co
VITE_A4F_API_KEY=your_a4f_api_key
VITE_A4F_BASE_URL=https://api.a4f.co/v1

# Google Gemini API Key (for Cognix AI assistant in chat)
# Get your API key from: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key

# Giphy API Key (for GIFs and Stickers in chat)
# Get your API key from: https://developers.giphy.com/
VITE_GIPHY_API_KEY=your_giphy_api_key
